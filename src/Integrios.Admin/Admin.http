@baseUrl      = http://localhost:5150
@globalKey    = Authorization: AdminKey global_admin_key:admin_bootstrap_secret
@swiftpayId   = aaaaaaaa-0000-0000-0000-000000000001
@webhookIntId = 00000000-0000-0000-0000-000000000001

###
# Health (no auth required)
GET {{baseUrl}}/health

###
# Auth probe — should 401 without key
GET {{baseUrl}}/admin/tenants

###
# ── Integrations ────────────────────────────────────────────────────────────

###
# List available integrations
GET {{baseUrl}}/admin/integrations
{{globalKey}}

###
# Get webhook integration
GET {{baseUrl}}/admin/integrations/{{webhookIntId}}
{{globalKey}}

###
# ── Tenants ─────────────────────────────────────────────────────────────────

###
# Create a tenant
POST {{baseUrl}}/admin/tenants
{{globalKey}}
Content-Type: application/json

{
  "slug": "acme-corp",
  "name": "Acme Corp",
  "environment": "production",
  "description": "Acme Corporation tenant"
}

###
# List tenants
GET {{baseUrl}}/admin/tenants
{{globalKey}}

###
# Get demo-swiftpay tenant
GET {{baseUrl}}/admin/tenants/{{swiftpayId}}
{{globalKey}}

###
# ── Connections ──────────────────────────────────────────────────────────────

###
# List connections for demo-swiftpay
GET {{baseUrl}}/admin/tenants/{{swiftpayId}}/connections
{{globalKey}}

###
# Get a seeded connection (swiftpay-webhook-source)
GET {{baseUrl}}/admin/tenants/{{swiftpayId}}/connections/aaaaaaaa-0000-0000-0000-000000000003
{{globalKey}}

###
# Create a new connection for demo-swiftpay
POST {{baseUrl}}/admin/tenants/{{swiftpayId}}/connections
{{globalKey}}
Content-Type: application/json

{
  "integrationId": "00000000-0000-0000-0000-000000000001",
  "name": "swiftpay-notifications-sink",
  "config": { "url": "http://localhost:5054/sink/swiftpay-notifications" },
  "environment": "demo",
  "description": "Notifications sink for SwiftPay"
}

###
# Update a connection (replace name + config)
PATCH {{baseUrl}}/admin/tenants/{{swiftpayId}}/connections/aaaaaaaa-0000-0000-0000-000000000004
{{globalKey}}
Content-Type: application/json

{
  "name": "swiftpay-ledger-sink",
  "config": { "url": "http://localhost:5054/sink/swiftpay-ledger-v2" },
  "description": "Updated ledger sink"
}

###
# Deactivate a connection
POST {{baseUrl}}/admin/tenants/{{swiftpayId}}/connections/aaaaaaaa-0000-0000-0000-000000000005/deactivate
{{globalKey}}
